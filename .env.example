# Revolut API Configuration
REVOLUT_API_KEY=your_64_character_api_key_here
REVOLUT_PRIVATE_KEY_PATH=./config/revolut_private.pem
REVOLUT_API_BASE_URL=https://api.revolut.com/api/1.0

# Trading Configuration
TRADING_MODE=paper  # paper or live
DEFAULT_STRATEGY=market_making  # market_making, momentum, mean_reversion, multi_strategy
RISK_LEVEL=conservative  # conservative, moderate, aggressive

# Supported Trading Pairs (comma-separated)
TRADING_PAIRS=BTC-USD,ETH-USD,SOL-USD

# Risk Management
MAX_POSITION_SIZE_PCT=2.0  # Max % of portfolio per trade
MAX_DAILY_LOSS_PCT=5.0     # Stop trading if daily loss exceeds this
STOP_LOSS_PCT=2.0          # Default stop loss percentage
TAKE_PROFIT_PCT=3.0        # Default take profit percentage

# Telegram Notifications (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
ENABLE_TELEGRAM=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/trading.log

# Paper Trading
PAPER_INITIAL_CAPITAL=10000.0