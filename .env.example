# ==============================================================================
# Revolut Trading Bot - Configuration Example
# ==============================================================================
#
# IMPORTANT: All sensitive credentials (API keys, private keys, tokens) are
# stored in 1Password ONLY. This file contains only non-sensitive settings.
#
# To set up credentials:
# 1. Install 1Password CLI: brew install --cask 1password-cli
# 2. Sign in: eval $(op signin)
# 3. Store credentials in 1Password vault 'revolut-trader'
#
# See docs/1PASSWORD_INTEGRATION.md for complete setup guide
# ==============================================================================

# Trading Configuration (these can be overridden via CLI args)
TRADING_MODE=paper  # paper or live (ALWAYS start with paper!)
DEFAULT_STRATEGY=market_making  # market_making, momentum, mean_reversion, multi_strategy
RISK_LEVEL=conservative  # conservative, moderate, aggressive

# Trading Pairs (comma-separated)
TRADING_PAIRS=BTC-USD,ETH-USD

# Risk Management Parameters
MAX_POSITION_SIZE_PCT=2.0  # Max % of portfolio per trade
MAX_DAILY_LOSS_PCT=5.0     # Stop trading if daily loss exceeds this
STOP_LOSS_PCT=2.0          # Default stop loss percentage
TAKE_PROFIT_PCT=3.0        # Default take profit percentage

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=./logs/trading.log

# Paper Trading Settings
PAPER_INITIAL_CAPITAL=10000.0  # Starting capital for paper trading

# API Configuration (non-sensitive)
REVOLUT_API_BASE_URL=https://api.revolut.com/api/1.0

# ==============================================================================
# CREDENTIALS (Stored in 1Password - DO NOT put here)
# ==============================================================================
#
# The following are retrieved automatically from 1Password:
# - REVOLUT_API_KEY (from 1Password field: REVOLUT_API_KEY)
# - REVOLUT_PRIVATE_KEY (from 1Password field: REVOLUT_PRIVATE_KEY)
# - TELEGRAM_BOT_TOKEN (from 1Password field: TELEGRAM_BOT_TOKEN)
# - TELEGRAM_CHAT_ID (from 1Password field: TELEGRAM_CHAT_ID)
#
# To store these in 1Password:
#
# op item edit revolut-trader-credentials --vault revolut-trader \
#   REVOLUT_API_KEY[concealed]="your-api-key" \
#   REVOLUT_PRIVATE_KEY[concealed]="$(cat config/revolut_private.pem)" \
#   TELEGRAM_BOT_TOKEN[concealed]="your-telegram-bot-token" \
#   TELEGRAM_CHAT_ID[concealed]="your-telegram-chat-id"
#
# ==============================================================================
